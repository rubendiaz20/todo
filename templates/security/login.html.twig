{% extends 'base.html.twig' %}
{% block nav %}{% endblock %}
{% block title %}Login{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Security/login.css') }}">
{% endblock %}

{% block body %}

    <div class="form-wrapper">
        <h1>Bienvenido</h1>
        <p class="subtitle">Inicia sesión para ver tus tareas</p>

        {{ form_start(loginForm, { action: path('app_login'), method: 'POST' }) }}
            <div class="form-group">
                {{ form_label(loginForm._username) }}
                {{ form_widget(loginForm._username) }}
            </div>
            <div class="form-group">
                {{ form_label(loginForm._password) }}
                {{ form_widget(loginForm._password) }}
            </div>

            {% if error %}
                <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <button type="submit" class="btn">Entrar</button>
        {{ form_end(loginForm) }}

        <div class="form-footer">
            ¿No tienes cuenta? <a href="{{ path('app_register') }}">Regístrate</a>
        </div>
    </div>

{% endblock %}
