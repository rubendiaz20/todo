{% extends 'base.html.twig' %}
{% block nav %}{% endblock %}
{% block title %}Crear Tarea{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Todo/createTodo.css') }}">
{% endblock %}

{% block body %}
    <div class="page-wrapper">

        <div class="page-header">
            <h1>Nueva tarea</h1>
            <p class="subtitle">Añade los detalles de tu tarea</p>
        </div>

        <div class="form-wrapper">
            <form method="post" action="{{ path('app_todo_create') }}">
                <div class="form-group">
                    <label for="title">Título</label>
                    <input type="text" id="title" name="title" placeholder="¿Qué tienes que hacer?" required>
                </div>
                <div class="form-group">
                    <label for="description">Descripción</label>
                    <textarea id="description" name="description" placeholder="Detalles opcionales..."></textarea>
                </div>
                <div class="actions">
                    <a href="{{ path('app_list') }}" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn">Crear tarea</button>
                </div>
            </form>
        </div>

    </div>
{% endblock %}
