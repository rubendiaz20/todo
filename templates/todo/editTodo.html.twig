{% extends 'base.html.twig' %}
{% block nav %}{% endblock %}
{% block title %}Editar Tarea{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Todo/editTodo.css') }}">
{% endblock %}

{% block body %}
    <div class="page-wrapper">

        <div class="page-header">
            <h1>Editar tarea</h1>
            <p class="subtitle">Modifica los detalles de tu tarea</p>
        </div>

        <div class="form-wrapper">
            <form method="post" action="{{ path('app_todo_edit', {id: todo.id}) }}">
                <div class="form-group">
                    <label for="title">Título</label>
                    <input type="text" id="title" name="title"
                           value="{{ todo.title }}" required>
                </div>
                <div class="form-group">
                    <label for="description">Descripción</label>
                    <textarea id="description" name="description">{{ todo.description }}</textarea>
                </div>
                <div class="actions">
                    <a href="{{ path('app_list') }}" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn">Guardar cambios</button>
                </div>
            </form>
        </div>

    </div>
{% endblock %}
