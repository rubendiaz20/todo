{% extends 'base.html.twig' %}
{% block nav %}{% endblock %}
{% block title %}{{ project is defined ? project.name : 'Mis tareas' }}{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Todo/listTodo.css') }}">
{% endblock %}
{% block body %}

    <a href="{{ path('app_project_list') }}" class="btn-logout">← Proyectos</a>

    <div class="page-wrapper">

        <div class="page-header">
            <h1>{{ project is defined ? project.name : 'Mis tareas' }}</h1>
            {% if project is defined and project.description %}
                <p class="project-description">{{ project.description }}</p>
            {% endif %}
            <p class="subtitle">{{ todos|length }} tarea{{ todos|length != 1 ? 's' : '' }}</p>
        </div>

        <div class="todo-list">
            {% for todo in todos %}
                <div class="todo-item {{ todo.done ? 'done' : '' }}">
                    <div class="checkbox-wrapper">
                        <a href="{{ path('app_todo_toggle', {id: todo.id}) }}">
                            <input type="checkbox" id="todo-{{ todo.id }}" {{ todo.done ? 'checked' : '' }}>
                            <label for="todo-{{ todo.id }}">{{ todo.done ? '✓' : '' }}</label>
                        </a>
                    </div>
                    <div class="todo-content">
                        <div class="todo-title">{{ todo.title }}</div>
                        {% if todo.description %}
                            <div class="todo-desc">{{ todo.description }}</div>
                        {% endif %}
                        <div class="todo-date">{{ todo.createdAt|date('d/m/Y') }}</div>
                    </div>
                    <div class="todo-actions">
                        <a href="{{ path('app_todo_edit', {id: todo.id}) }}" class="btn-edit">✏️</a>
                        <a href="{{ path('app_todo_delete', {id: todo.id}) }}" class="btn-danger">🗑</a>
                    </div>
                </div>
            {% else %}
                <div class="empty-state">
                    <span class="empty-icon">📋</span>
                    <p>No tienes tareas todavía</p>
                </div>
            {% endfor %}
        </div>

        <a href="{{ path('app_todo_create', project is defined ? {project_id: project.id} : {}) }}" class="btn-create">
            + Crear tarea
        </a>

    </div>

{% endblock %}
